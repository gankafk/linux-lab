# Plantilla de credenciales de la app.
#
# Copiar a /etc/labapp/labapp.env, rellenar DB_PASSWORD y proteger:
#   sudo mkdir -p /etc/labapp
#   sudo cp labapp.env.example /etc/labapp/labapp.env   # y editar la contraseña
#   sudo chmod 600 /etc/labapp/labapp.env
#   sudo chown root:root /etc/labapp/labapp.env
#
# El fichero REAL (con la contraseña) NUNCA se sube al repo. Esto es solo la plantilla.

DB_HOST=10.10.10.30
DB_PORT=5432
DB_NAME=labapp
DB_USER=appuser
DB_PASSWORD=CAMBIAR_POR_LA_CONTRASEÑA_REAL
